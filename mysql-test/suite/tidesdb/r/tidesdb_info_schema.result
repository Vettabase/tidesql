# ---- setup ----
CREATE TABLE t1 (
id INT PRIMARY KEY,
val VARCHAR(200)
) ENGINE=TidesDB;
INSERT INTO t1 VALUES (1, REPEAT('a', 100));
INSERT INTO t1 VALUES (2, REPEAT('b', 100));
INSERT INTO t1 VALUES (3, REPEAT('c', 100));
