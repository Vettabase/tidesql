[mysqld]
port     = 3306
socket   = /tmp/mariadb.sock
user     = mysql
pid_file = mariadb.pid

# Paths
basedir               = /usr/local/mariadb
datadir               = /usr/local/mariadb/data/misc
log_error             = /usr/local/mariadb/log/mariadb.err
slow_query_log_file   = /usr/local/mariadb/log/slow.log
general_log_file      = /usr/local/mariadb/log/general.log

# Networking
max_connections = 151

# InnoDB
default_storage_engine        = InnoDB
innodb_buffer_pool_size       = 128M
innodb_log_file_size          = 48M
innodb_flush_log_at_trx_commit = 1
innodb_file_per_table         = ON

# Logging
slow_query_log      = ON
long_query_time     = 2

# Character set
character-set-server = utf8mb4
collation-server     = utf8mb4_general_ci

# TidesDB plugin — loaded at startup
plugin_maturity  = experimental
plugin_load_add  = ha_tidesdb.so

# TidesDB settings (defaults shown — tune as needed)
tidesdb_flush_threads      = 2
tidesdb_compaction_threads = 2
tidesdb_block_cache_size   = 268435456
tidesdb_max_open_sstables  = 256
tidesdb_log_level          = WARN

[client]
port                  = 3306
socket                = /tmp/mariadb.sock
default-character-set = utf8mb4

[mysqldump]
single_transaction
quick
max_allowed_packet = 64M

[mariadb-backup]
# mariabackup settings (defaults are fine)
